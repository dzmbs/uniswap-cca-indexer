ENVIO_API_TOKEN=        # Required for HyperSync access
BASE_RPC_URL=           # Optional override. Default fallback: https://base.llamarpc.com
ARB_RPC_URL=            # Optional override. Default fallback: https://api.zan.top/arb-one
ETH_RPC_URL=            # Optional override. Default fallback: https://eth.llamarpc.com
UNICHAIN_RPC_URL=       # Optional override. Default fallback: https://unichain-rpc.publicnode.com

# Effect rate limits (requests per second).
# Values below tested on Alchemy free tier RPCs.
# For public RPCs (llamarpc, publicnode) reduce these significantly (e.g. 2-6 rps).
EFFECT_RPS_READ_TOTAL_SUPPLY=40
EFFECT_RPS_READ_AUCTION_SNAPSHOT=20
EFFECT_RPS_READ_STEPS=40
EFFECT_RPS_READ_CHECKPOINT_BUNDLE=50
EFFECT_RPS_READ_TICK_AT_BLOCK=40
EFFECT_RPS_READ_TICK_PAIR=50
